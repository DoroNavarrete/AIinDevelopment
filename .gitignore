node_modules/
frontend/dist/
frontend/.vite/

# ─── Environment / Secrets ────────────────────────────────────────────────────
# Never commit real .env files — only .env.example is safe to commit
.env
.env.local
.env.*.local
backend/.env

# ─── Logs ─────────────────────────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pip-log.txt

# ─── OS artefacts ─────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

